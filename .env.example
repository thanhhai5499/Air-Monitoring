# Air Monitoring - root env template for Docker Compose
NODE_ENV=production

# SQL Server (use a Tailscale / LAN / public IP reachable from the Docker host)
DB_SERVER=100.82.249.100
DB_PORT=1433
DB_NAME=AirMonitoring
DB_USER=sa
DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=3h

# CORS - include the Cloudflare Tunnel public domain
CORS_ORIGIN=https://app.aiot-shtplabs.com,http://localhost:3000

# Input data ingestion API key
DATA_API_KEY=change_this_api_key
